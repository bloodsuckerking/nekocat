# NekoCat 配置模板
# 复制此文件为 .env 并填入你的 API keys

# 后端选择: claude | openai | ollama | mock
NEKOCAT_BACKEND__PROVIDER=claude
NEKOCAT_BACKEND__MODEL=
NEKOCAT_BACKEND__API_KEY=
NEKOCAT_BACKEND__API_BASE=
NEKOCAT_BACKEND__MAX_TOKENS=1024
NEKOCAT_BACKEND__TEMPERATURE=0.9

# 角色预设: classic_neko | tsundere_neko | kuudere_neko
NEKOCAT_PERSONA__PRESET=classic_neko
# 或指定自定义 YAML:
# NEKOCAT_PERSONA__FILE=

# CLI 设置
NEKOCAT_CLI__TYPEWRITER_SPEED=0.02
NEKOCAT_CLI__COLOR_THEME=pink

# === API Key 单独设置 (也支持) ===
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
